<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FreeMCP"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.03" />

        <View
            android:id="@+id/status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/status_dot_red" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="DISCONNECTED"
            android:textColor="#555555"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textAllCaps="true" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111111" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="12dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/ip_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="IP or URL (e.g. host:port)"
                android:inputType="textNoSuggestions"
                android:paddingHorizontal="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#333333"
                android:textSize="14sp"
                android:fontFamily="monospace" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/connect_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="CONNECT"
            android:textColor="#000000"
            android:textSize="12sp"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="12dp"
            android:fontFamily="sans-serif-medium"
            android:minWidth="100dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        app:cardBackgroundColor="#060606"
        app:cardCornerRadius="16dp"
        app:strokeColor="#141414"
        app:strokeWidth="1dp">

        <ScrollView
            android:id="@+id/log_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/log_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#8AFF8A"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="KILL SWITCH"
            android:textColor="#555555"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/kill_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            app:thumbTint="#FF5252"
            app:trackTint="#33FF5252" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CHARACTER MODE"
            android:textColor="#555555"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/character_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="#2196F3"
            app:trackTint="#332196F3" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        android:paddingTop="4dp">

        <!-- Unified Text Input -->        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="14dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/prompt_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Ask or command..."
                android:paddingHorizontal="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#333333"
                android:textSize="14sp"
                android:maxLines="1"
                android:imeOptions="actionSend"
                android:inputType="text" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/send_button"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="#FFFFFF"
            app:backgroundTint="#2196F3"
            app:cornerRadius="14dp" />
    </LinearLayout>

</LinearLayout>
